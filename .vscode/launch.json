    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
            // "url": "http://localhost:8080", //if want to use this, run this on terminal, php -S localhost:8080 to start a local server, then you can use this url to launch the browser
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}"
        },
        /*
        {
            "name": "Launch Edge", //name only
            "request": "launch", //default command
            "type": "msedge", //type of debugger, if use chrome, change to "chrome", if use firefox, change to "firefox"
            "file": "${workspaceFolder}/index.html", //path to the file to launch, if you want to launch a local file, change this to "file:///path/to/your/file.html"
            "url": "http://localhost:8080", //url to launch, if you want to launch a local file, change this to "file:///path/to/your/file.html", no need to set this if you set "file" above
            "webRoot": "${workspaceFolder}" //default web root, if you want to set a different web root, change this to the path of your web root //example: "webRoot": "${workspaceFolder}/src"
        },*/

    ]
}